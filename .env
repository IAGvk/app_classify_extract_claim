# ── Google Cloud ────────────────────────────────────────────────────────────
GCP_PROJECT_ID=your-gcp-project-id
GCP_LOCATION=us-central1
GCP_GEMINI_MODEL=gemini-2.0-flash-001

# ── Local development overrides ─────────────────────────────────────────────
# Set to "true" to skip all GCP calls and use mock LLM responses
MOCK_LLM=true

# ── Python path (needed when running run.py directly) ────────────────────────
PYTHONPATH=/Users/s748779/end

# ── File paths ───────────────────────────────────────────────────────────────
# Path to the vulnerability phrases CSV (copy from repo root)
VULNERABILITY_PHRASES_PATH=app_classify_extract_claim/data/vulnera_phrases.csv

# Path to the mock policy store JSON
MOCK_POLICIES_PATH=app_classify_extract_claim/data/mock_policies.json

# Output JSONL files
LODGED_CLAIMS_PATH=app_classify_extract_claim/data/lodged_claims.jsonl
EXCEPTIONS_PATH=app_classify_extract_claim/data/exceptions_queue.jsonl

# ── HTTP proxy (if required for corporate network) ───────────────────────────
# HTTPS_PROXY=http://your-proxy:8080
# HTTP_PROXY=http://your-proxy:8080
