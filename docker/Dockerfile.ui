# ── Streamlit Inbox Simulator UI ─────────────────────────────────────────────
# Build context: repo root (app_classify_extract_claim parent directory)
#
# Build:  docker build -f docker/Dockerfile.ui -t claims-ui .
# Run:    docker run -p 8501:8501 -e API_URL=http://api:8000 claims-ui

FROM python:3.11-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PYTHONPATH=/app

WORKDIR /app

COPY app_classify_extract_claim/requirements.txt ./requirements.txt
RUN pip install --no-cache-dir --upgrade pip \
    && pip install --no-cache-dir -r requirements.txt

COPY app_classify_extract_claim/ ./app_classify_extract_claim/

EXPOSE 8501

HEALTHCHECK --interval=15s --timeout=5s --start-period=15s --retries=3 \
    CMD python -c "import urllib.request; urllib.request.urlopen('http://localhost:8501/_stcore/health')" \
    || exit 1

CMD ["streamlit", "run", "app_classify_extract_claim/ui/streamlit_app.py", \
    "--server.port=8501", \
    "--server.address=0.0.0.0", \
    "--server.headless=true", \
    "--browser.gatherUsageStats=false"]
